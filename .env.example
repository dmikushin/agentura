# Agentura configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# --- Server ---
# Public URL where agents reach the server (HTTPS recommended)
AGENTURA_URL=https://agents.example.com
# Server listen port (inside container)
AGENTURA_PORT=7850

# --- Host integration ---
# UID/GID to run the server container as (for file permissions)
UID=1000
GID=1000
# Host tmux socket path (mounted read-only into container)
TMUX_SOCKET_PATH=/tmp/tmux-1000

# --- HTTPS tunnel (autossh → gateway) ---
# Set these if you want the server accessible via public HTTPS.
# Remove the agentura-tunnel service from docker-compose.yml if not needed.
GATEWAY_HOST=gateway.example.com
GATEWAY_PORT=22
GATEWAY_USER=agentura
TUNNEL_PORT=49160
TUNNEL_KEY=./secrets/tunnel_key
