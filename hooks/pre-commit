#!/bin/sh
set -e

cd "$(git rev-parse --show-toplevel)"

# Syntax check all Python files being committed
echo "[pre-commit] Checking Python syntax..."
git diff --cached --name-only --diff-filter=ACM | grep '\.py$' | while read f; do
    python3 -c "import ast; ast.parse(open('$f').read())" || exit 1
done

# Build Go binaries
echo "[pre-commit] Building Go binaries..."
make build || exit 1

# Go unit tests
echo "[pre-commit] Running Go tests..."
go test ./... || exit 1

# Add bin/ to PATH so e2e tests find agentura-run, agentura-mcp-backend
export PATH="$(pwd)/bin:$PATH"

# E2E test: requires agentura server running
echo "[pre-commit] Running e2e tests..."
# Load .env for AGENTURA_URL
if [ -f .env ]; then
    export $(grep -v '^#' .env | grep -v '^UID=' | grep -v '^GID=' | xargs)
fi
# Start server if not already running; remember whether we started it
STARTED_BY_HOOK=0
if ! docker compose ps --status running 2>/dev/null | grep -q agentura-server; then
    docker compose up -d --wait 2>/dev/null
    sleep 1
    STARTED_BY_HOOK=1
fi
python3 tests/test_read_stream.py
python3 tests/test_chat.py
python3 tests/test_remote.py
# Only stop if we started it
if [ "$STARTED_BY_HOOK" = "1" ]; then
    docker compose down 2>/dev/null
fi
